# Travel Agent 环境变量配置
# 复制此文件为 .env.local 并填入你的 API Key

# ========== 智谱 AI (必需) ==========
# 获取地址：https://open.bigmodel.cn/
OPENAI_API_KEY=your_zhipu_api_key_here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ========== 和风天气 QWeather (必需) ==========
# 获取地址：https://dev.qweather.com/
# WEATHER_API_HOST: 你的专属 API 域名 (在控制台获取)
WEATHER_API_KEY=your_qweather_api_key_here
WEATHER_API_HOST=your_host.re.qweatherapi.com

# ========== 可选配置 ==========
# NODE_ENV=production
